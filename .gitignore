# Ignore Python local cache across repo
**/__pycache__/

# Ignore BuildStream local state
.bst
.bst2
.cache/*

*.img
*.raw
*.tar
.ovmf-vars.fd
.build-out

# Local AI agent state (opencode sessions, drafts)
# Skills are committed; everything else is ignored
.opencode/*
!.opencode/skills/

# Git worktrees
.worktrees/
# files/filemap.json and files/fakecap-manifest.tsv are pre-committed (like Cargo.lock)
# Delete both and re-run: python3 scripts/gen-filemap.py to regenerate after BST element changes
files/xattr-db/
files/fakecap/fakecap-restore
files/fakecap/fakecap.so
